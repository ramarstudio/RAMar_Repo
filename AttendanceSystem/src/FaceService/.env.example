# ── FaceService — Variables de entorno ─────────────────────────────────
# Copiar como .env y ajustar según el entorno.
# Todas las variables llevan prefijo FACE_

# Servidor
FACE_HOST=0.0.0.0
FACE_PORT=5001

# Modelo InsightFace
FACE_DETECTION_MODEL=buffalo_l
FACE_GPU_ID=-1

# Umbrales
FACE_SIMILARITY_THRESHOLD=0.60
FACE_MAX_FACES_PER_IMAGE=1

# Seguridad (vacío = sin autenticación, solo para desarrollo)
FACE_API_KEY=

# Logging
FACE_LOG_LEVEL=INFO
