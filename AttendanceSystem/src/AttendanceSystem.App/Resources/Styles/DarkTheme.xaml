<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Backgrounds ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBg"          Color="#121921"/>
    <SolidColorBrush x:Key="CardBg"         Color="#1A2332"/>
    <SolidColorBrush x:Key="CardAltBg"      Color="#1E2738"/>
    <SolidColorBrush x:Key="AccentBg"       Color="#1E3A5F"/>
    <SolidColorBrush x:Key="LoginPanelBg"   Color="#0F1923"/>

    <!-- ── Borders ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderSubtle"   Color="#2A3746"/>
    <SolidColorBrush x:Key="BorderMuted"    Color="#3D3018"/>

    <!-- ── Text ─────────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary"    Color="#E8EEF2"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="#C8D6E0"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#78909C"/>
    <SolidColorBrush x:Key="TextDim"        Color="#546E7A"/>
    <SolidColorBrush x:Key="TextSubtle"     Color="#6B8DA6"/>
    <SolidColorBrush x:Key="TextLabel"      Color="#90A4AE"/>

    <!-- ── Accent colors ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentBlue"     Color="#7EB8DA"/>
    <SolidColorBrush x:Key="PastelGreen"    Color="#81C995"/>
    <SolidColorBrush x:Key="PastelOrange"   Color="#F4A97D"/>
    <SolidColorBrush x:Key="PastelPink"     Color="#E8879B"/>
    <SolidColorBrush x:Key="PastelPurple"   Color="#B8A9D4"/>
    <SolidColorBrush x:Key="PastelTeal"     Color="#7EC8B8"/>

    <!-- ── Badge backgrounds ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BadgeGreenBg"   Color="#1A3025"/>
    <SolidColorBrush x:Key="BadgeRedBg"     Color="#3D1A1A"/>
    <SolidColorBrush x:Key="BadgeOrangeBg"  Color="#2D2518"/>
    <SolidColorBrush x:Key="BadgeBlueBg"    Color="#1A3050"/>
    <SolidColorBrush x:Key="BadgePurpleBg"  Color="#2D1A3D"/>

    <!-- ── Warning / Info ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WarningBg"      Color="#2D2518"/>
    <SolidColorBrush x:Key="WarningBorder"  Color="#3D3018"/>
    <SolidColorBrush x:Key="WarningText"    Color="#C8A878"/>
    <SolidColorBrush x:Key="WarningIcon"    Color="#F57F17"/>
    <SolidColorBrush x:Key="ErrorBg"        Color="#3D1A1A"/>
    <SolidColorBrush x:Key="ErrorText"      Color="#E8879B"/>

    <!-- ── DataGrid ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBg"      Color="#1A2332"/>
    <SolidColorBrush x:Key="GridRowAltBg"   Color="#1E2738"/>
    <SolidColorBrush x:Key="GridHeaderBg"   Color="#1E2A3A"/>

    <!-- ── Zoom bar ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ZoomBarBg"      Color="#1A2332"/>
    <SolidColorBrush x:Key="ZoomBtnBg"      Color="#2A3746"/>
    <SolidColorBrush x:Key="ZoomBtnHover"   Color="#3A4756"/>

    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <Color x:Key="SidebarBg1">#0A1628</Color>
    <Color x:Key="SidebarBg2">#0D1B2A</Color>
    <Color x:Key="SidebarBg3">#112240</Color>
    <SolidColorBrush x:Key="SidebarAccent"      Color="#4FC3F7"/>
    <SolidColorBrush x:Key="SidebarAccentDim"   Color="#4FC3F780"/>
    <SolidColorBrush x:Key="SidebarSectionLabel" Color="#37474F"/>
    <SolidColorBrush x:Key="NavInactiveFg"      Color="#90A4AE"/>
    <SolidColorBrush x:Key="NavActiveBg"        Color="#275E87"/>
    <Color x:Key="SidebarHover">#FFFFFF15</Color>
    <Color x:Key="SidebarHoverBorder">#4FC3F750</Color>
    <Color x:Key="SidebarAccentLine">#4FC3F730</Color>

    <!-- ── Banner / Dashboard ──────────────────────────────────────────────── -->
    <Color x:Key="BannerBg1">#1A2332</Color>
    <Color x:Key="BannerBg2">#1E3A5F</Color>
    <SolidColorBrush x:Key="SectionLabelFg"  Color="#A8C4D6"/>
    <SolidColorBrush x:Key="BannerGreeting"  Color="#8EAEC4"/>

    <!-- ── KPI badge icon backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="KpiBadgeBg1"    Color="#1E3045"/>
    <SolidColorBrush x:Key="KpiBadgeBg2"    Color="#1A3025"/>
    <SolidColorBrush x:Key="KpiBadgeBg3"    Color="#2D2518"/>
    <SolidColorBrush x:Key="KpiBadgeBg4"    Color="#2D1A22"/>
    <SolidColorBrush x:Key="KpiBadgeBg5"    Color="#221E2D"/>
    <SolidColorBrush x:Key="KpiBadgeBg6"    Color="#1A2D28"/>

    <!-- ── Ranking headers ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="RankingHeaderBg1" Color="#2A1E1E"/>
    <SolidColorBrush x:Key="RankingHeaderBg2" Color="#1A2D25"/>

    <!-- ── Counter / Gauge ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CounterBg"      Color="#253545"/>
    <SolidColorBrush x:Key="GaugeBg"        Color="#2A2535"/>

    <!-- ── Form labels ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FormLabelFg"    Color="#546E7A"/>

    <!-- ── Export button backgrounds ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="ExportPdfBg"       Color="#3D1F28"/>
    <SolidColorBrush x:Key="ExportPdfHover"    Color="#4D2A35"/>
    <SolidColorBrush x:Key="ExportCsvBg"       Color="#1A3025"/>
    <SolidColorBrush x:Key="ExportCsvHover"    Color="#224035"/>
    <SolidColorBrush x:Key="GenerateBtnHover"  Color="#254A6F"/>

    <!-- ── DataGrid themed style ─────────────────────────────────────────── -->
    <SolidColorBrush x:Key="HeatmapWarning"    Color="#F4D97D"/>
    <SolidColorBrush x:Key="GridLineBrush"     Color="#2A3746"/>
    <SolidColorBrush x:Key="GridSelectedBg"    Color="#1E3A5F"/>

    <Style x:Key="ThemedDataGrid" TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
        <Setter Property="Background"              Value="{DynamicResource CardBg}"/>
        <Setter Property="RowBackground"            Value="{DynamicResource GridRowBg}"/>
        <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridRowAltBg}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderSubtle}"/>
        <Setter Property="BorderThickness"          Value="0"/>
    </Style>

    <!-- ── Camera / MarcajeView ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CameraBg"        Color="#111827"/>
    <SolidColorBrush x:Key="MarcajeHeaderFg"  Color="#7EB8DA"/>
    <SolidColorBrush x:Key="BtnEntradaBg"     Color="#2E7D32"/>
    <SolidColorBrush x:Key="BtnSalidaBg"      Color="#C62828"/>
    <SolidColorBrush x:Key="BtnBreakBg"       Color="#E65100"/>
    <SolidColorBrush x:Key="CameraLedColor"   Color="#4CAF50"/>
    <SolidColorBrush x:Key="OverlayBg"        Color="#60000000"/>
    <SolidColorBrush x:Key="OverlayBottomBg"  Color="#80000000"/>

</ResourceDictionary>
