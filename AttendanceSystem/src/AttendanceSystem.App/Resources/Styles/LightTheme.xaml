<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Backgrounds ──────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AppBg"          Color="#F5F7FA"/>
    <SolidColorBrush x:Key="CardBg"         Color="#FFFFFF"/>
    <SolidColorBrush x:Key="CardAltBg"      Color="#F8FAFC"/>
    <SolidColorBrush x:Key="AccentBg"       Color="#E3F2FD"/>
    <SolidColorBrush x:Key="LoginPanelBg"   Color="#FFFFFF"/>

    <!-- ── Borders ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BorderSubtle"   Color="#E0E6ED"/>
    <SolidColorBrush x:Key="BorderMuted"    Color="#FFE082"/>

    <!-- ── Text ─────────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TextPrimary"    Color="#1A2332"/>
    <SolidColorBrush x:Key="TextSecondary"  Color="#37474F"/>
    <SolidColorBrush x:Key="TextMuted"      Color="#607D8B"/>
    <SolidColorBrush x:Key="TextDim"        Color="#78909C"/>
    <SolidColorBrush x:Key="TextSubtle"     Color="#607D8B"/>
    <SolidColorBrush x:Key="TextLabel"      Color="#90A4AE"/>

    <!-- ── Accent colors ────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="AccentBlue"     Color="#1565C0"/>
    <SolidColorBrush x:Key="PastelGreen"    Color="#2E7D32"/>
    <SolidColorBrush x:Key="PastelOrange"   Color="#E65100"/>
    <SolidColorBrush x:Key="PastelPink"     Color="#C62828"/>
    <SolidColorBrush x:Key="PastelPurple"   Color="#6A1B9A"/>
    <SolidColorBrush x:Key="PastelTeal"     Color="#00897B"/>

    <!-- ── Badge backgrounds ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="BadgeGreenBg"   Color="#E8F5E9"/>
    <SolidColorBrush x:Key="BadgeRedBg"     Color="#FFEBEE"/>
    <SolidColorBrush x:Key="BadgeOrangeBg"  Color="#FFF3E0"/>
    <SolidColorBrush x:Key="BadgeBlueBg"    Color="#E3F2FD"/>
    <SolidColorBrush x:Key="BadgePurpleBg"  Color="#F3E5F5"/>

    <!-- ── Warning / Info ───────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="WarningBg"      Color="#FFF8E1"/>
    <SolidColorBrush x:Key="WarningBorder"  Color="#FFE082"/>
    <SolidColorBrush x:Key="WarningText"    Color="#795548"/>
    <SolidColorBrush x:Key="WarningIcon"    Color="#F57F17"/>
    <SolidColorBrush x:Key="ErrorBg"        Color="#FFEBEE"/>
    <SolidColorBrush x:Key="ErrorText"      Color="#C62828"/>

    <!-- ── DataGrid ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="GridRowBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="GridRowAltBg"   Color="#F8FAFC"/>
    <SolidColorBrush x:Key="GridHeaderBg"   Color="#F0F4F8"/>

    <!-- ── Zoom bar ─────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="ZoomBarBg"      Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ZoomBtnBg"      Color="#E0E6ED"/>
    <SolidColorBrush x:Key="ZoomBtnHover"   Color="#D0D6DD"/>

    <!-- ── Sidebar ─────────────────────────────────────────────────────────── -->
    <Color x:Key="SidebarBg1">#1A237E</Color>
    <Color x:Key="SidebarBg2">#1E3A5F</Color>
    <Color x:Key="SidebarBg3">#1565C0</Color>
    <SolidColorBrush x:Key="SidebarAccent"      Color="#BBDEFB"/>
    <SolidColorBrush x:Key="SidebarAccentDim"   Color="#90CAF980"/>
    <SolidColorBrush x:Key="SidebarSectionLabel" Color="#90CAF9"/>
    <SolidColorBrush x:Key="NavInactiveFg"      Color="#B0BEC5"/>
    <SolidColorBrush x:Key="NavActiveBg"        Color="#1565C0"/>
    <Color x:Key="SidebarHover">#FFFFFF20</Color>
    <Color x:Key="SidebarHoverBorder">#BBDEFB80</Color>
    <Color x:Key="SidebarAccentLine">#BBDEFB40</Color>

    <!-- ── Banner / Dashboard ──────────────────────────────────────────────── -->
    <Color x:Key="BannerBg1">#E3F2FD</Color>
    <Color x:Key="BannerBg2">#BBDEFB</Color>
    <SolidColorBrush x:Key="SectionLabelFg"  Color="#37474F"/>
    <SolidColorBrush x:Key="BannerGreeting"  Color="#607D8B"/>

    <!-- ── KPI badge icon backgrounds ──────────────────────────────────────── -->
    <SolidColorBrush x:Key="KpiBadgeBg1"    Color="#E3F2FD"/>
    <SolidColorBrush x:Key="KpiBadgeBg2"    Color="#E8F5E9"/>
    <SolidColorBrush x:Key="KpiBadgeBg3"    Color="#FFF3E0"/>
    <SolidColorBrush x:Key="KpiBadgeBg4"    Color="#FFEBEE"/>
    <SolidColorBrush x:Key="KpiBadgeBg5"    Color="#F3E5F5"/>
    <SolidColorBrush x:Key="KpiBadgeBg6"    Color="#E0F2F1"/>

    <!-- ── Ranking headers ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="RankingHeaderBg1" Color="#FFF3E0"/>
    <SolidColorBrush x:Key="RankingHeaderBg2" Color="#E8F5E9"/>

    <!-- ── Counter / Gauge ─────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CounterBg"      Color="#E3F2FD"/>
    <SolidColorBrush x:Key="GaugeBg"        Color="#E0E0E0"/>

    <!-- ── Form labels ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FormLabelFg"    Color="#607D8B"/>

    <!-- ── Export button backgrounds ───────────────────────────────────────── -->
    <SolidColorBrush x:Key="ExportPdfBg"       Color="#FFEBEE"/>
    <SolidColorBrush x:Key="ExportPdfHover"    Color="#FFCDD2"/>
    <SolidColorBrush x:Key="ExportCsvBg"       Color="#E8F5E9"/>
    <SolidColorBrush x:Key="ExportCsvHover"    Color="#C8E6C9"/>
    <SolidColorBrush x:Key="GenerateBtnHover"  Color="#BBDEFB"/>

    <!-- ── Camera / MarcajeView ────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="CameraBg"       Color="#263238"/>
    <SolidColorBrush x:Key="MarcajeHeaderFg" Color="#1565C0"/>

</ResourceDictionary>
