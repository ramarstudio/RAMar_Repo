<UserControl x:Class="AttendanceSystem.App.Views.HistorialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="HistorialView_Loaded"
             Background="{DynamicResource MaterialDesignBackground}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ─── HEADER + FILTRO ─── -->
        <md:Card Grid.Row="0" Margin="0,0,0,14" Padding="20,14" UniformCornerRadius="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="History" Width="26" Height="26"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Historial de Marcajes"
                                   Style="{DynamicResource MaterialDesignHeadline6TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="txtSubtitulo"
                               Text="Mostrando registros del mes actual"
                               Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Margin="36,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <md:PackIcon Kind="CalendarRange" Width="18" Height="18"
                                 Foreground="{DynamicResource MaterialDesignBodyLight}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="dpMes" Width="180"
                                md:HintAssist.Hint="Filtrar por mes"
                                md:HintAssist.IsFloating="True"
                                Style="{DynamicResource MaterialDesignOutlinedDatePicker}"
                                SelectedDateChanged="DpMes_SelectedDateChanged"
                                VerticalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </md:Card>

        <!-- ─── TABLA ─── -->
        <md:Card Grid.Row="1" Margin="0,0,0,14" Padding="4" UniformCornerRadius="8">
            <Grid>
                <TextBlock x:Name="txtSinDatos"
                           Text="No se encontraron marcajes para el período seleccionado."
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           Visibility="Collapsed"/>

                <DataGrid x:Name="dgHistorial"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                          SelectionMode="Single"
                          BorderThickness="0" CanUserResizeRows="False"
                          Style="{DynamicResource MaterialDesignDataGrid}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Fecha"    Binding="{Binding Fecha}"    Width="120"/>
                        <DataGridTextColumn Header="Hora"     Binding="{Binding Hora}"     Width="85"/>
                        <DataGridTextColumn Header="Tipo"     Binding="{Binding Tipo}"     Width="110"/>
                        <DataGridTextColumn Header="Tardanza" Binding="{Binding Tardanza}" Width="95"/>
                        <DataGridTextColumn Header="Minutos"  Binding="{Binding Minutos}"  Width="95"/>
                        <DataGridTextColumn Header="Método"   Binding="{Binding Metodo}"   Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </md:Card>

        <!-- ─── RESUMEN ─── -->
        <md:Card Grid.Row="2" Padding="16,10" UniformCornerRadius="6">
            <StackPanel Orientation="Horizontal">
                <md:PackIcon Kind="InformationOutline" Width="16" Height="16"
                             Foreground="{DynamicResource MaterialDesignBodyLight}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="txtResumen"
                           Text="Cargando..."
                           Style="{DynamicResource MaterialDesignBody2TextBlock}"
                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </md:Card>
    </Grid>
</UserControl>
