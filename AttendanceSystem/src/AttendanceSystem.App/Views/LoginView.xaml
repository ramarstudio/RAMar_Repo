<UserControl x:Class="AttendanceSystem.App.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="420"/>
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo — Branding -->
        <Border Grid.Column="0" Background="#1A237E">
            <Grid>
                <!-- Fondo decorativo con degradado -->
                <Border>
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#1A237E" Offset="0"/>
                            <GradientStop Color="#283593" Offset="0.5"/>
                            <GradientStop Color="#1565C0" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <!-- Logo / Ícono -->
                    <Border Width="80" Height="80" CornerRadius="40"
                            Background="#FFFFFF20" HorizontalAlignment="Center" Margin="0,0,0,24">
                        <TextBlock Text="R" FontSize="42" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="RAMar Studio" FontSize="34" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Control de Asistencia" FontSize="16"
                               Foreground="#90CAF9" HorizontalAlignment="Center" Margin="0,8,0,32"/>

                    <!-- Features list -->
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="#64B5F6"
                                                     Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="  Reconocimiento Facial" Foreground="#E3F2FD" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="#64B5F6"
                                                     Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="  Control en Tiempo Real" Foreground="#E3F2FD" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="CheckCircle" Foreground="#64B5F6"
                                                     Width="20" Height="20" VerticalAlignment="Center"/>
                            <TextBlock Text="  Reportes y Análisis" Foreground="#E3F2FD" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Footer versión -->
                <TextBlock Text="v1.0.0" Foreground="#FFFFFF50" FontSize="11"
                           VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,20,16"/>
            </Grid>
        </Border>

        <!-- Panel derecho — Formulario -->
        <Border Grid.Column="1" Background="White">
            <StackPanel VerticalAlignment="Center" Margin="48,0">
                <TextBlock Text="Bienvenido" FontSize="28" FontWeight="Bold"
                           Foreground="#1A237E" Margin="0,0,0,4"/>
                <TextBlock Text="Ingresa tus credenciales para continuar"
                           FontSize="13" Foreground="#757575" Margin="0,0,0,36"/>

                <!-- Campo Usuario -->
                <TextBox x:Name="txtUsername"
                         Style="{StaticResource MaterialDesignOutlinedTextBox}"
                         materialDesign:HintAssist.Hint="Usuario"
                         materialDesign:HintAssist.FloatingScale="0.8"
                         materialDesign:TextFieldAssist.HasClearButton="True"
                         FontSize="14" Margin="0,0,0,20"
                         KeyDown="TxtUsername_KeyDown"/>

                <!-- Campo Contraseña -->
                <PasswordBox x:Name="txtPassword"
                             Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                             materialDesign:HintAssist.Hint="Contraseña"
                             materialDesign:HintAssist.FloatingScale="0.8"
                             FontSize="14" Margin="0,0,0,8"/>

                <!-- Error -->
                <TextBlock x:Name="txtError"
                           Foreground="#D32F2F" FontSize="12" TextWrapping="Wrap"
                           Visibility="Collapsed" Margin="0,0,0,16"
                           HorizontalAlignment="Center"/>

                <!-- Botón Login -->
                <Button x:Name="btnLogin"
                        Content="INGRESAR AL SISTEMA"
                        Style="{StaticResource MaterialDesignRaisedButton}"
                        materialDesign:ButtonAssist.CornerRadius="8"
                        Background="#1A237E" Foreground="White"
                        BorderThickness="0" Height="48" FontSize="14" FontWeight="Bold"
                        Cursor="Hand" Margin="0,8,0,0"
                        Click="BtnLogin_Click"/>

                <TextBlock Text="RAMar · Sistema de Control de Asistencia"
                           FontSize="11" Foreground="#BDBDBD"
                           HorizontalAlignment="Center" Margin="0,32,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
