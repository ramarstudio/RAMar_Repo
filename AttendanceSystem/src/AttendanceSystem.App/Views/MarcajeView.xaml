<UserControl x:Class="AttendanceSystem.App.Views.MarcajeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Loaded="MarcajeView_Loaded" Unloaded="MarcajeView_Unloaded">

    <Grid Background="{DynamicResource AppBg}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="360"/>
        </Grid.ColumnDefinitions>

        <!-- CÁMARA EN VIVO -->
        <materialDesign:Card Grid.Column="0" Margin="16" UniformCornerRadius="12"
                             materialDesign:ElevationAssist.Elevation="Dp4">
            <Grid Background="{DynamicResource CameraBg}" ClipToBounds="True">
                <Image x:Name="imgCamara" Stretch="UniformToFill"/>

                <!-- Overlay superior con info -->
                <Border VerticalAlignment="Top" Background="{DynamicResource OverlayBg}" Padding="16,10">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource CameraLedColor}" VerticalAlignment="Center"
                                 Margin="0,0,8,0"/>
                        <TextBlock x:Name="txtEstadoCamara" Text="Cámara activa"
                                   Foreground="White" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Overlay inferior con fecha -->
                <Border VerticalAlignment="Bottom" Background="{DynamicResource OverlayBottomBg}" Padding="16,10">
                    <TextBlock x:Name="txtFechaHora" Foreground="White" FontSize="14"
                               HorizontalAlignment="Center"/>
                </Border>
            </Grid>
        </materialDesign:Card>

        <!-- PANEL DE ACCIÓN -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Margin="0,16,16,16">
            <StackPanel>
                <!-- Header -->
                <materialDesign:Card Margin="0,0,0,12" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp2" Padding="20">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <materialDesign:PackIcon Kind="FaceRecognition" Width="24" Height="24"
                                                     Foreground="{DynamicResource MarcajeHeaderFg}" VerticalAlignment="Center"
                                                     Margin="0,0,8,0"/>
                            <TextBlock Text="Registro de Asistencia" FontSize="18" FontWeight="Bold"
                                       Foreground="{DynamicResource MarcajeHeaderFg}" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Selecciona el tipo de marcaje y presiona el botón"
                                   FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Botones de marcaje -->
                <materialDesign:Card Margin="0,0,0,12" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp2" Padding="20">
                    <StackPanel>
                        <!-- ENTRADA -->
                        <Button x:Name="btnEntrada"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Background="{DynamicResource BtnEntradaBg}" Foreground="White"
                                BorderThickness="0" Height="56" FontSize="15" FontWeight="Bold"
                                Cursor="Hand" Margin="0,0,0,10"
                                Click="BtnEntrada_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Login" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="ENTRADA" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- SALIDA -->
                        <Button x:Name="btnSalida"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Background="{DynamicResource BtnSalidaBg}" Foreground="White"
                                BorderThickness="0" Height="56" FontSize="15" FontWeight="Bold"
                                Cursor="Hand" Margin="0,0,0,10"
                                Click="BtnSalida_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Logout" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="SALIDA" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- BREAK -->
                        <Button x:Name="btnBreak"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                materialDesign:ButtonAssist.CornerRadius="10"
                                Background="{DynamicResource BtnBreakBg}" Foreground="White"
                                BorderThickness="0" Height="56" FontSize="15" FontWeight="Bold"
                                Cursor="Hand"
                                Click="BtnBreak_Click">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="PauseCircle" Width="22" Height="22"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="BREAK" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </materialDesign:Card>

                <!-- Panel resultado -->
                <materialDesign:Card x:Name="panelResultado"
                                     Margin="0,0,0,12" UniformCornerRadius="12"
                                     materialDesign:ElevationAssist.Elevation="Dp2" Padding="20"
                                     Visibility="Collapsed">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="txtResultadoIcono" FontSize="36"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock x:Name="txtResultadoMensaje" FontSize="14" FontWeight="SemiBold"
                                   TextWrapping="Wrap" HorizontalAlignment="Center"
                                   TextAlignment="Center"/>
                        <TextBlock x:Name="txtResultadoTardanza" FontSize="12" Foreground="{DynamicResource ErrorText}"
                                   HorizontalAlignment="Center" Margin="0,6,0,0"
                                   Visibility="Collapsed"/>
                    </StackPanel>
                </materialDesign:Card>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
