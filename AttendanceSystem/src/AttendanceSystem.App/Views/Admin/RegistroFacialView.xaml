<UserControl x:Class="AttendanceSystem.App.Views.Admin.RegistroFacialView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource AppBg}"
             Loaded="View_Loaded" Unloaded="View_Unloaded">

    <Grid Margin="28,24,28,28">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ PANEL IZQUIERDO: Lista de empleados ═══ -->
        <StackPanel Grid.Column="0" Margin="0,0,18,0">

            <!-- Header -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="20,16" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="38" Height="38" CornerRadius="10" Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#1E88E5" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="FaceRecognition" Width="22" Height="22"
                                                 Foreground="White" HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Registro Facial" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Selecciona un empleado" FontSize="11"
                                   Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Lista de empleados -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="8"
                    MaxHeight="600">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="icEmpleados">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Click="BtnSeleccionarEmpleado_Click" Tag="{Binding}"
                                        Cursor="Hand" Margin="2,2">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bd" Background="Transparent" CornerRadius="10"
                                                    Padding="14,10" BorderThickness="0">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Avatar -->
                                                    <Border Grid.Column="0" Width="36" Height="36" CornerRadius="18"
                                                            Background="{DynamicResource BadgeBlueBg}" Margin="0,0,12,0">
                                                        <materialDesign:PackIcon Kind="Account" Width="20" Height="20"
                                                                                 Foreground="{DynamicResource AccentBlue}"
                                                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>

                                                    <!-- Info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Nombre}" FontSize="13" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextPrimary}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding Codigo}" FontSize="10"
                                                                   Foreground="{DynamicResource TextMuted}"/>
                                                    </StackPanel>

                                                    <!-- Estado -->
                                                    <materialDesign:PackIcon Grid.Column="2"
                                                        Kind="{Binding EstadoIcono}" Width="20" Height="20"
                                                        VerticalAlignment="Center"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bd" Property="Background" Value="{DynamicResource CardAltBg}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </StackPanel>

        <!-- ═══ PANEL DERECHO: Cámara + Acciones ═══ -->
        <StackPanel Grid.Column="1">

            <!-- Panel de cámara -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="20" Margin="0,0,0,14">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel>
                    <!-- Info del empleado seleccionado -->
                    <Border x:Name="pnlEmpleadoInfo" Visibility="Collapsed"
                            Background="{DynamicResource AccentBg}" CornerRadius="10" Padding="16,12" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <materialDesign:PackIcon Kind="AccountCircle" Width="32" Height="32"
                                                     Foreground="{DynamicResource AccentBlue}" Margin="0,0,12,0"
                                                     VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="txtEmpleadoNombre" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock x:Name="txtEmpleadoCodigo" FontSize="11"
                                           Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                            <Border Grid.Column="2" x:Name="badgeEstado" CornerRadius="6" Padding="10,4"
                                    VerticalAlignment="Center">
                                <TextBlock x:Name="txtEstado" FontSize="11" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Cámara -->
                    <Border Background="{DynamicResource CameraBg}" CornerRadius="12"
                            MinHeight="360" Margin="0,0,0,14">
                        <Grid>
                            <Image x:Name="imgCamara" Stretch="Uniform"/>

                            <!-- Placeholder cuando no hay empleado seleccionado -->
                            <StackPanel x:Name="pnlPlaceholder" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <materialDesign:PackIcon Kind="CameraOutline" Width="64" Height="64"
                                                         Foreground="{DynamicResource TextDim}"
                                                         HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                <TextBlock x:Name="txtPlaceholder" Text="Selecciona un empleado para iniciar"
                                           FontSize="14" Foreground="{DynamicResource TextDim}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Acciones -->
                    <StackPanel x:Name="pnlAcciones" Visibility="Collapsed">

                        <!-- Paso 1: Consentimiento -->
                        <Border x:Name="pnlConsentimiento" Background="{DynamicResource WarningBg}"
                                CornerRadius="10" Padding="16,14" Margin="0,0,0,12"
                                BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Consentimiento requerido" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource WarningText}"/>
                                    <TextBlock Text="El empleado debe autorizar el uso de datos biométricos"
                                               FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"/>
                                </StackPanel>
                                <Button Grid.Column="1" x:Name="btnConsentimiento" Click="BtnConsentimiento_Click"
                                        Height="36" Padding="16,0"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="ShieldCheck" Width="16" Height="16" Margin="0,0,6,0"/>
                                        <TextBlock Text="Otorgar" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <!-- Paso 2: Captura -->
                        <StackPanel x:Name="pnlCaptura" Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button x:Name="btnCapturar" Click="BtnCapturar_Click"
                                    Height="48" Padding="28,0" Margin="0,0,12,0"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Camera" Width="20" Height="20" Margin="0,0,8,0"/>
                                    <TextBlock Text="Capturar rostro" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                            <Button x:Name="btnReemplazar" Click="BtnCapturar_Click"
                                    Height="48" Padding="28,0" Visibility="Collapsed"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="Refresh" Width="20" Height="20" Margin="0,0,8,0"/>
                                    <TextBlock Text="Reemplazar registro" FontSize="14"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Feedback -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>
