<UserControl x:Class="AttendanceSystem.App.Views.Admin.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Loaded="ReportesView_Loaded"
             Background="{DynamicResource AppBg}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="24,20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- HEADER -->
            <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,14" Padding="20,14" Background="{DynamicResource CardBg}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="FileChartOutline" Width="26" Height="26"
                                     Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Reportes de Asistencia" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Genera y exporta resúmenes mensuales por empleado"
                               FontSize="12" Foreground="{DynamicResource TextSubtle}" Margin="36,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- PARÁMETROS -->
            <Border Grid.Row="1" CornerRadius="12" Margin="0,0,0,14" Padding="20,16" Background="{DynamicResource CardBg}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="cmbEmpleado" Grid.Column="0"
                              md:HintAssist.Hint="Empleado"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" Margin="0,2"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox x:Name="cmbMes" Grid.Column="2"
                              md:HintAssist.Hint="Mes"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"/>

                    <ComboBox x:Name="cmbAnio" Grid.Column="4"
                              md:HintAssist.Hint="Año"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"/>

                    <Button Grid.Column="6" Click="BtnGenerar_Click" VerticalAlignment="Bottom"
                            Margin="0,0,0,2" Cursor="Hand" Height="40" Padding="20,0"
                            BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Background="{DynamicResource AccentBg}" Height="40" Padding="20,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <md:PackIcon Kind="ChartBar" Foreground="{DynamicResource AccentBlue}" Width="16" Height="16"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <TextBlock Text="Generar Reporte" Foreground="{DynamicResource SectionLabelFg}" FontSize="13"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{DynamicResource GenerateBtnHover}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- RESULTADOS -->
            <StackPanel x:Name="PanelResultados" Grid.Row="2" Visibility="Collapsed" Margin="0,0,0,14">

                <!-- Header con export -->
                <Border CornerRadius="12" Margin="0,0,0,14" Padding="20,14" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtTituloReporte" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="txtPeriodo" FontSize="12" Foreground="{DynamicResource TextSubtle}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1" Click="BtnExportarPdf_Click" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="{DynamicResource ExportPdfBg}" Padding="16,8">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="FilePdfBox" Foreground="{DynamicResource PastelPink}" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="PDF" Foreground="{DynamicResource PastelPink}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource ExportPdfHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button Grid.Column="3" Click="BtnExportarCsv_Click" Cursor="Hand" BorderThickness="0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="{DynamicResource ExportCsvBg}" Padding="16,8">
                                        <StackPanel Orientation="Horizontal">
                                            <md:PackIcon Kind="FileDelimited" Foreground="{DynamicResource PastelGreen}" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="CSV" Foreground="{DynamicResource PastelGreen}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{DynamicResource ExportCsvHover}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- KPI Cards -->
                <UniformGrid Rows="1" Columns="4">
                    <Border CornerRadius="12" Margin="0,0,8,0" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource PastelGreen}" CornerRadius="12,12,0,0"/>
                            <StackPanel Grid.Row="1" Margin="20,14,20,16">
                                <md:PackIcon Kind="CalendarCheck" Width="28" Height="28" Foreground="{DynamicResource PastelGreen}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtAsistencias" Text="—" FontSize="38" FontWeight="Bold" Foreground="{DynamicResource PastelGreen}"/>
                                <TextBlock Text="Días Asistidos" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="4,0,4,0" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource PastelOrange}" CornerRadius="12,12,0,0"/>
                            <StackPanel Grid.Row="1" Margin="20,14,20,16">
                                <md:PackIcon Kind="ClockAlert" Width="28" Height="28" Foreground="{DynamicResource PastelOrange}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtTardanzas" Text="—" FontSize="38" FontWeight="Bold" Foreground="{DynamicResource PastelOrange}"/>
                                <TextBlock Text="Tardanzas" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="4,0,4,0" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource PastelPink}" CornerRadius="12,12,0,0"/>
                            <StackPanel Grid.Row="1" Margin="20,14,20,16">
                                <md:PackIcon Kind="CalendarRemove" Width="28" Height="28" Foreground="{DynamicResource PastelPink}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFaltas" Text="—" FontSize="38" FontWeight="Bold" Foreground="{DynamicResource PastelPink}"/>
                                <TextBlock Text="Faltas" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border CornerRadius="12" Margin="8,0,0,0" Background="{DynamicResource CardBg}">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="4"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="{DynamicResource PastelPurple}" CornerRadius="12,12,0,0"/>
                            <StackPanel Grid.Row="1" Margin="20,14,20,16">
                                <md:PackIcon Kind="TimerSand" Width="28" Height="28" Foreground="{DynamicResource PastelPurple}" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtMinutos" Text="—" FontSize="38" FontWeight="Bold" Foreground="{DynamicResource PastelPurple}"/>
                                <TextBlock Text="Min. Tardanza" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </UniformGrid>
            </StackPanel>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Grid.Row="3"
                       FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"
                       Visibility="Collapsed" Margin="0,4,0,0"/>
        </Grid>
    </ScrollViewer>
</UserControl>
