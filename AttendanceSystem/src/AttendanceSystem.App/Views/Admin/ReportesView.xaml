<UserControl x:Class="AttendanceSystem.App.Views.Admin.ReportesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Loaded="ReportesView_Loaded"
             Background="{DynamicResource MaterialDesignBackground}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ─── HEADER ─── -->
            <md:Card Grid.Row="0" Margin="0,0,0,14" Padding="20,14" UniformCornerRadius="8">
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <md:PackIcon Kind="FileChartOutline" Width="26" Height="26"
                                     Foreground="{DynamicResource PrimaryHueMidBrush}"
                                     VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Reportes de Asistencia"
                                   Style="{DynamicResource MaterialDesignHeadline6TextBlock}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Genera y exporta resúmenes mensuales por empleado"
                               Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                               Foreground="{DynamicResource MaterialDesignBodyLight}"
                               Margin="36,2,0,0"/>
                </StackPanel>
            </md:Card>

            <!-- ─── PARÁMETROS ─── -->
            <md:Card Grid.Row="1" Margin="0,0,0,14" Padding="20,16" UniformCornerRadius="8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="170"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ComboBox x:Name="cmbEmpleado" Grid.Column="0"
                              md:HintAssist.Hint="Empleado"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" Margin="0,2"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox x:Name="cmbMes" Grid.Column="2"
                              md:HintAssist.Hint="Mes"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"/>

                    <ComboBox x:Name="cmbAnio" Grid.Column="4"
                              md:HintAssist.Hint="Año"
                              md:HintAssist.IsFloating="True"
                              Style="{DynamicResource MaterialDesignOutlinedComboBox}"/>

                    <Button Grid.Column="6"
                            Style="{DynamicResource MaterialDesignRaisedButton}"
                            Click="BtnGenerar_Click" VerticalAlignment="Bottom" Margin="0,0,0,2">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="ChartBar" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Generar Reporte" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </md:Card>

            <!-- ─── RESULTADOS (colapsable) ─── -->
            <StackPanel x:Name="PanelResultados" Grid.Row="2"
                        Visibility="Collapsed" Margin="0,0,0,14">

                <!-- Encabezado con botones de exportar -->
                <md:Card Margin="0,0,0,14" Padding="20,14" UniformCornerRadius="8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtTituloReporte"
                                       Style="{DynamicResource MaterialDesignSubtitle1TextBlock}"
                                       FontWeight="Bold"/>
                            <TextBlock x:Name="txtPeriodo"
                                       Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                                       Foreground="{DynamicResource MaterialDesignBodyLight}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#C62828" BorderBrush="#C62828"
                                Click="BtnExportarPdf_Click">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FilePdfBox" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="PDF" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="3"
                                Style="{DynamicResource MaterialDesignRaisedButton}"
                                Background="#2E7D32" BorderBrush="#2E7D32"
                                Click="BtnExportarCsv_Click">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="FileDelimited" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="CSV" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </md:Card>

                <!-- KPI Cards -->
                <UniformGrid Rows="1" Columns="4">

                    <!-- Asistencias -->
                    <md:Card Margin="0,0,8,0" Padding="20" UniformCornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#2E7D32" CornerRadius="2"/>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <md:PackIcon Kind="CalendarCheck" Width="28" Height="28"
                                             Foreground="#2E7D32" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtAsistencias" Text="—"
                                           FontSize="40" FontWeight="Bold" Foreground="#2E7D32"/>
                                <TextBlock Text="Días Asistidos"
                                           Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </md:Card>

                    <!-- Tardanzas -->
                    <md:Card Margin="4,0,4,0" Padding="20" UniformCornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#E65100" CornerRadius="2"/>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <md:PackIcon Kind="ClockAlert" Width="28" Height="28"
                                             Foreground="#E65100" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtTardanzas" Text="—"
                                           FontSize="40" FontWeight="Bold" Foreground="#E65100"/>
                                <TextBlock Text="Tardanzas"
                                           Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </md:Card>

                    <!-- Faltas -->
                    <md:Card Margin="4,0,4,0" Padding="20" UniformCornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#B71C1C" CornerRadius="2"/>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <md:PackIcon Kind="CalendarRemove" Width="28" Height="28"
                                             Foreground="#B71C1C" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtFaltas" Text="—"
                                           FontSize="40" FontWeight="Bold" Foreground="#B71C1C"/>
                                <TextBlock Text="Faltas"
                                           Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </md:Card>

                    <!-- Minutos tardanza -->
                    <md:Card Margin="8,0,0,0" Padding="20" UniformCornerRadius="8">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Border Grid.Row="0" Background="#6A1B9A" CornerRadius="2"/>
                            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                                <md:PackIcon Kind="TimerSand" Width="28" Height="28"
                                             Foreground="#6A1B9A" Margin="0,0,0,6"/>
                                <TextBlock x:Name="txtMinutos" Text="—"
                                           FontSize="40" FontWeight="Bold" Foreground="#6A1B9A"/>
                                <TextBlock Text="Min. Tardanza"
                                           Style="{DynamicResource MaterialDesignCaptionTextBlock}"
                                           Foreground="{DynamicResource MaterialDesignBodyLight}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </md:Card>
                </UniformGrid>
            </StackPanel>

            <!-- ─── FEEDBACK ─── -->
            <TextBlock x:Name="txtMensaje" Grid.Row="3"
                       Style="{DynamicResource MaterialDesignBody2TextBlock}"
                       FontWeight="SemiBold" HorizontalAlignment="Center"
                       Visibility="Collapsed" Margin="0,4,0,0"/>
        </Grid>
    </ScrollViewer>
</UserControl>
