<UserControl x:Class="AttendanceSystem.App.Views.Admin.AdminShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Loaded="AdminShell_Loaded">

    <UserControl.Resources>
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#90A4AE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF15"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#4FC3F750"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0A1628" Offset="0"/>
                    <GradientStop Color="#0D1B2A" Offset="0.4"/>
                    <GradientStop Color="#112240" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo / Branding -->
                <StackPanel Grid.Row="0" Margin="0,24,0,6">
                    <Grid HorizontalAlignment="Center" Margin="0,0,0,12">
                        <Border Width="60" Height="60" CornerRadius="30" Background="Transparent">
                            <Border.BorderBrush>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#4FC3F7" Offset="0"/>
                                    <GradientStop Color="#1565C0" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.BorderBrush>
                            <Border.BorderThickness><Thickness>2</Thickness></Border.BorderThickness>
                        </Border>
                        <Border Width="52" Height="52" CornerRadius="26"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1E88E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="R" FontSize="24" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="RAMar" FontSize="20" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Panel Administrativo" FontSize="10"
                               Foreground="#4FC3F780" HorizontalAlignment="Center" Margin="0,3,0,16"/>
                    <Border Height="1" Margin="20,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#4FC3F730" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </StackPanel>

                <!-- Nav buttons -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <StackPanel>

                        <!-- MENÚ PRINCIPAL -->
                        <TextBlock Text="MENÚ PRINCIPAL"
                                   Foreground="#37474F" FontSize="9" FontWeight="Bold"
                                   Margin="20,6,0,6"/>

                        <Button x:Name="btnNavDashboard" Tag="dashboard"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Dashboard — Vista general del sistema">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnNavUsuarios" Tag="usuarios"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Usuarios — Gestión de accesos y roles">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Usuarios" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnNavMarcajes" Tag="marcajes"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Marcajes — Consulta y registro de asistencias">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ClockCheck" Width="20" Height="20"
                                                             VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    <TextBlock Text="Marcajes" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Button>

                        <Button x:Name="btnNavHorarios" Tag="horarios"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Horarios — Asignación de turnos por empleado">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="CalendarClock" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Horarios" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Margin="20,8">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.05"/>
                            </Border.Background>
                        </Border>

                        <!-- ANÁLISIS -->
                        <TextBlock Text="ANÁLISIS"
                                   Foreground="#37474F" FontSize="9" FontWeight="Bold"
                                   Margin="20,0,0,6"/>

                        <Button x:Name="btnNavReportes" Tag="reportes"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Reportes — Análisis y exportación de datos">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Reportes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnNavAuditoria" Tag="auditoria"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Auditoría — Historial de acciones del sistema">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ShieldSearch" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Auditoría" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Margin="20,8">
                            <Border.Background>
                                <SolidColorBrush Color="White" Opacity="0.05"/>
                            </Border.Background>
                        </Border>

                        <!-- SISTEMA -->
                        <TextBlock Text="SISTEMA"
                                   Foreground="#37474F" FontSize="9" FontWeight="Bold"
                                   Margin="20,0,0,6"/>

                        <Button x:Name="btnNavConfig" Tag="configuracion"
                                Style="{StaticResource NavBtnStyle}" Click="NavBtn_Click"
                                ToolTip="Configuración — Parámetros del sistema">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Cog" Width="20" Height="20"
                                                         VerticalAlignment="Center" Margin="0,0,12,0"/>
                                <TextBlock Text="Configuración" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- ALERTAS DEL DÍA -->
                        <Border x:Name="pnlAlertas" Margin="16,14,16,4" Visibility="Collapsed"
                                CornerRadius="10" Padding="12,10">
                            <Border.Background>
                                <SolidColorBrush Color="#E65100" Opacity="0.12"/>
                            </Border.Background>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <materialDesign:PackIcon Kind="AlertCircle" Width="14" Height="14"
                                                             Foreground="#FFB74D" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ALERTAS HOY" FontSize="9" FontWeight="Bold"
                                               Foreground="#FFB74D" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <Border Width="6" Height="6" CornerRadius="3"
                                            Background="#E65100" Margin="2,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtAlertaTardanzas" FontSize="11" Foreground="#ECEFF1"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="6" Height="6" CornerRadius="3"
                                            Background="#AD1457" Margin="2,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="txtAlertaAusencias" FontSize="11" Foreground="#ECEFF1"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- User info + logout -->
                <StackPanel Grid.Row="2" Margin="16,0,16,16">
                    <Border Height="1" Margin="0,0,0,12">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="Transparent" Offset="0"/>
                                <GradientStop Color="#4FC3F730" Offset="0.5"/>
                                <GradientStop Color="Transparent" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <!-- User card -->
                    <Border CornerRadius="10" Padding="10,8" Margin="0,0,0,10">
                        <Border.Background>
                            <SolidColorBrush Color="White" Opacity="0.05"/>
                        </Border.Background>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="17">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#1565C0" Offset="0"/>
                                        <GradientStop Color="#1E88E5" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="A" FontSize="15" FontWeight="Bold"
                                           Foreground="White" HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock x:Name="txtNombreAdmin" Text="Admin"
                                           Foreground="#ECEFF1" FontSize="12" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" MaxWidth="120"/>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="6" Height="6" CornerRadius="3"
                                            Background="#4CAF50" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="En línea" Foreground="#4FC3F7" FontSize="10"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Logout button -->
                    <Button Content="Cerrar Sesión" Click="BtnLogout_Click"
                            Height="34" Cursor="Hand" FontSize="11" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#B71C1C" Offset="0"/>
                                            <GradientStop Color="#C62828" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Logout" Width="15" Height="15"
                                                                 Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="White" FontSize="11"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Right edge shadow -->
        <Border Grid.Column="0" Width="6" HorizontalAlignment="Right" IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#00000030" Offset="0"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- CONTENT AREA -->
        <ContentControl x:Name="ShellContent" Grid.Column="1" Background="#F0F4F8"/>
    </Grid>
</UserControl>
