<UserControl x:Class="AttendanceSystem.App.Views.Admin.AdminShellView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignHeight="700" d:DesignWidth="1100"
             Loaded="AdminShell_Loaded">

    <UserControl.Resources>
        <Style x:Key="NavBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#90A4AE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height" Value="52"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0,16,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderThickness="3,0,0,0"
                                BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FFFFFF15"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- SIDEBAR -->
        <Border Grid.Column="0">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0D1B2A" Offset="0"/>
                    <GradientStop Color="#1B2A3B" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,28,0,8">
                    <Border Width="56" Height="56" CornerRadius="28"
                            Background="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,12">
                        <TextBlock Text="R" FontSize="28" FontWeight="Bold"
                                   Foreground="White" HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="RAMar" FontSize="22" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="Panel Administrativo" FontSize="10"
                               Foreground="#546E7A" HorizontalAlignment="Center" Margin="0,2,0,20"/>
                    <Rectangle Height="1" Margin="20,0">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="White" Opacity="0.08"/>
                        </Rectangle.Fill>
                    </Rectangle>
                </StackPanel>

                <!-- Nav buttons -->
                <StackPanel Grid.Row="1" Margin="0,8,0,0">
                    <Button x:Name="btnNavDashboard" Tag="dashboard"
                            Style="{StaticResource NavBtnStyle}"
                            Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ViewDashboard" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Dashboard" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnNavUsuarios" Tag="usuarios"
                            Style="{StaticResource NavBtnStyle}"
                            Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="AccountGroup" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Usuarios" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnNavMarcajes" Tag="marcajes"
                            Style="{StaticResource NavBtnStyle}"
                            Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ClockCheck" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Marcajes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnNavReportes" Tag="reportes"
                            Style="{StaticResource NavBtnStyle}"
                            Click="NavBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ChartBar" Width="20" Height="20"
                                                     VerticalAlignment="Center" Margin="0,0,12,0"/>
                            <TextBlock Text="Reportes" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- User info + logout -->
                <StackPanel Grid.Row="2" Margin="16,0,16,20">
                    <Rectangle Height="1" Margin="0,0,0,14">
                        <Rectangle.Fill>
                            <SolidColorBrush Color="White" Opacity="0.08"/>
                        </Rectangle.Fill>
                    </Rectangle>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="36" Height="36" CornerRadius="18" Background="#1565C0">
                            <TextBlock Text="A" FontSize="16" FontWeight="Bold"
                                       Foreground="White" HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtNombreAdmin" Text="Admin"
                                       Foreground="#ECEFF1" FontSize="13" FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" MaxWidth="140"/>
                            <TextBlock Text="Administrador" Foreground="#546E7A" FontSize="10"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Cerrar Sesión" Click="BtnLogout_Click"
                            Height="36" Cursor="Hand" FontSize="12" FontWeight="SemiBold">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" CornerRadius="8" Background="#C62828">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <materialDesign:PackIcon Kind="Logout" Width="16" Height="16"
                                                                 Foreground="White" Margin="0,0,6,0"/>
                                        <TextBlock Text="{TemplateBinding Content}"
                                                   Foreground="White" FontSize="12"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#D32F2F"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- CONTENT AREA -->
        <ContentControl x:Name="ShellContent" Grid.Column="1" Background="#F5F5F5"/>
    </Grid>
</UserControl>
