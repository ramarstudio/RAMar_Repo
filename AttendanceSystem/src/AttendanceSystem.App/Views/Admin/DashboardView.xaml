<UserControl x:Class="AttendanceSystem.App.Views.Admin.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d" d:DesignHeight="1400" d:DesignWidth="1100"
             Loaded="DashboardView_Loaded"
             Background="{DynamicResource AppBg}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24,20,24,24">

            <!-- GREETING BANNER -->
            <Border CornerRadius="14" Margin="0,0,0,20" Padding="28,22">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{DynamicResource BannerBg1}" Offset="0"/>
                        <GradientStop Color="{DynamicResource BannerBg2}" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Ellipse Width="200" Height="200" HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,-60,-40,0" Opacity="0.04">
                        <Ellipse.Fill><SolidColorBrush Color="#7EB8DA"/></Ellipse.Fill>
                    </Ellipse>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock x:Name="txtSaludo" Text="Buenos días,"
                                       FontSize="13" Foreground="{DynamicResource BannerGreeting}" Margin="0,0,0,4"/>
                            <TextBlock x:Name="txtNombreAdmin" Text="Administrador"
                                       FontSize="26" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="txtFechaHoy"
                                       FontSize="12" Foreground="{DynamicResource TextSubtle}" Margin="0,6,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Click="BtnRefresh_Click"
                                Height="36" Padding="18,0" Cursor="Hand"
                                BorderThickness="1" Background="Transparent">
                            <Button.BorderBrush><SolidColorBrush Color="#4A7A9B" Opacity="0.5"/></Button.BorderBrush>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd" CornerRadius="8" Background="Transparent"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="1" Padding="18,0" Height="36">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <md:PackIcon Kind="Refresh" Foreground="{DynamicResource AccentBlue}" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,6,0"/>
                                            <TextBlock Text="Actualizar" Foreground="{DynamicResource AccentBlue}" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#FFFFFF08"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- RESUMEN SEMANAL -->
            <StackPanel Orientation="Horizontal" Margin="2,0,0,12">
                <md:PackIcon Kind="CalendarWeek" Width="18" Height="18"
                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Esta Semana" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionLabelFg}" VerticalAlignment="Center"/>
            </StackPanel>

            <ItemsControl x:Name="icSemana" Margin="0,0,0,20">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="12" Margin="0,0,8,0" Padding="14"
                                Background="{DynamicResource CardBg}">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="{Binding DiaNombre}" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource AccentBlue}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding FechaCorta}" FontSize="10" Foreground="{DynamicResource TextSubtle}"
                                           HorizontalAlignment="Center" Margin="0,2,0,10"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#81C995" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Asistencias}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource PastelGreen}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#F4A97D" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Tardanzas}" FontSize="13" Foreground="{DynamicResource PastelOrange}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Border Width="8" Height="8" CornerRadius="4" Background="#E8879B" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Ausencias}" FontSize="13" Foreground="{DynamicResource PastelPink}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- KPI CARDS -->
            <StackPanel Orientation="Horizontal" Margin="2,0,0,12">
                <md:PackIcon Kind="ChartLine" Width="18" Height="18"
                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Resumen del Día" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionLabelFg}" VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Rows="2" Columns="3" Margin="0,0,0,20">
                <!-- Empleados Activos -->
                <Border CornerRadius="12" Margin="0,0,8,8" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#7EB8DA" CornerRadius="12,12,0,0"/>
                        <StackPanel Grid.Row="1" Margin="20,16,20,18">
                            <Border Background="{DynamicResource KpiBadgeBg1}" CornerRadius="8" Width="40" Height="40"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <md:PackIcon Kind="AccountGroup" Width="22" Height="22" Foreground="{DynamicResource AccentBlue}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txtTotalEmpleados" Text="—"
                                       FontSize="34" FontWeight="Bold" Foreground="{DynamicResource AccentBlue}" LineHeight="36"/>
                            <TextBlock Text="Empleados Activos" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Asistencias Hoy -->
                <Border CornerRadius="12" Margin="4,0,4,8" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#81C995" CornerRadius="12,12,0,0"/>
                        <StackPanel Grid.Row="1" Margin="20,16,20,18">
                            <Grid Margin="0,0,0,10">
                                <Border Background="{DynamicResource KpiBadgeBg2}" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <md:PackIcon Kind="CheckCircle" Width="22" Height="22" Foreground="{DynamicResource PastelGreen}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="badgeTendAsist" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        CornerRadius="8" Padding="6,2" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon x:Name="iconTendAsist" Kind="TrendingUp" Width="12" Height="12"
                                                     Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtTendAsist" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="txtAsistenciasHoy" Text="—"
                                       FontSize="34" FontWeight="Bold" Foreground="{DynamicResource PastelGreen}" LineHeight="36"/>
                            <TextBlock Text="Asistencias Hoy" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tardanzas Hoy -->
                <Border CornerRadius="12" Margin="8,0,0,8" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#F4A97D" CornerRadius="12,12,0,0"/>
                        <StackPanel Grid.Row="1" Margin="20,16,20,18">
                            <Grid Margin="0,0,0,10">
                                <Border Background="{DynamicResource KpiBadgeBg3}" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <md:PackIcon Kind="ClockAlert" Width="22" Height="22" Foreground="{DynamicResource PastelOrange}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="badgeTendTard" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        CornerRadius="8" Padding="6,2" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon x:Name="iconTendTard" Kind="TrendingDown" Width="12" Height="12"
                                                     Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtTendTard" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="txtTardanzasHoy" Text="—"
                                       FontSize="34" FontWeight="Bold" Foreground="{DynamicResource PastelOrange}" LineHeight="36"/>
                            <TextBlock Text="Tardanzas Hoy" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Ausencias Hoy -->
                <Border CornerRadius="12" Margin="0,0,8,0" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#E8879B" CornerRadius="12,12,0,0"/>
                        <StackPanel Grid.Row="1" Margin="20,16,20,18">
                            <Grid Margin="0,0,0,10">
                                <Border Background="{DynamicResource KpiBadgeBg4}" CornerRadius="8" Width="40" Height="40" HorizontalAlignment="Left">
                                    <md:PackIcon Kind="AccountOff" Width="22" Height="22" Foreground="{DynamicResource PastelPink}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Border x:Name="badgeTendAus" HorizontalAlignment="Right" VerticalAlignment="Top"
                                        CornerRadius="8" Padding="6,2" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal">
                                        <md:PackIcon x:Name="iconTendAus" Kind="TrendingDown" Width="12" Height="12"
                                                     Margin="0,0,3,0" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="txtTendAus" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                            <TextBlock x:Name="txtAusenciasHoy" Text="—"
                                       FontSize="34" FontWeight="Bold" Foreground="{DynamicResource PastelPink}" LineHeight="36"/>
                            <TextBlock Text="Ausencias Hoy" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Tasa Asistencia -->
                <Border CornerRadius="12" Margin="4,0,4,0" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#B8A9D4" CornerRadius="12,12,0,0"/>
                        <Grid Grid.Row="1" Margin="20,16,20,18">
                            <StackPanel>
                                <Border Background="{DynamicResource KpiBadgeBg5}" CornerRadius="8" Width="40" Height="40"
                                        HorizontalAlignment="Left" Margin="0,0,0,10">
                                    <md:PackIcon Kind="GaugeEmpty" Width="22" Height="22" Foreground="{DynamicResource PastelPurple}"
                                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="txtTasaAsistencia" Text="—"
                                           FontSize="34" FontWeight="Bold" Foreground="{DynamicResource PastelPurple}" LineHeight="36"/>
                                <Grid Height="6" Margin="0,8,0,0">
                                    <Border Background="{DynamicResource GaugeBg}" CornerRadius="3"/>
                                    <Border x:Name="barGauge" Background="#B8A9D4" CornerRadius="3"
                                            HorizontalAlignment="Left" Width="0"/>
                                </Grid>
                                <TextBlock Text="Tasa Asistencia" FontSize="11" Foreground="{DynamicResource TextSubtle}" Margin="0,4,0,0" FontWeight="Medium"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Marcajes 7 días -->
                <Border CornerRadius="12" Margin="8,0,0,0" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="4"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#7EC8B8" CornerRadius="12,12,0,0"/>
                        <StackPanel Grid.Row="1" Margin="20,16,20,18">
                            <Border Background="{DynamicResource KpiBadgeBg6}" CornerRadius="8" Width="40" Height="40"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <md:PackIcon Kind="CalendarMultiselect" Width="22" Height="22" Foreground="{DynamicResource PastelTeal}"
                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock x:Name="txtMarcajes7Dias" Text="—"
                                       FontSize="34" FontWeight="Bold" Foreground="{DynamicResource PastelTeal}" LineHeight="36"/>
                            <TextBlock Text="Marcajes (7 días)" FontSize="11" Foreground="{DynamicResource TextSubtle}" FontWeight="Medium"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </UniformGrid>

            <!-- CHARTS: LINE + DONUT -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14" Background="{DynamicResource AccentBg}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="TrendingUp" Width="16" Height="16"
                                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Tendencia — Últimos 14 días"
                                           FontSize="13" FontWeight="Medium" Foreground="{DynamicResource SectionLabelFg}"/>
                            </StackPanel>
                        </Border>
                        <lvc:CartesianChart Grid.Row="1" x:Name="chartLinea" Margin="8,4,8,8"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="12" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="220"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14" Background="{DynamicResource AccentBg}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="ChartDonut" Width="16" Height="16"
                                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Distribución Hoy"
                                           FontSize="13" FontWeight="Medium" Foreground="{DynamicResource SectionLabelFg}"/>
                            </StackPanel>
                        </Border>
                        <lvc:PieChart Grid.Row="1" x:Name="chartDonut" Margin="8,4,8,8"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- RANKINGS -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" CornerRadius="12" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14" Background="{DynamicResource RankingHeaderBg1}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AlertCircle" Width="16" Height="16"
                                             Foreground="{DynamicResource PastelOrange}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Top 5 — Más Tardanzas (30 días)"
                                           FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PastelOrange}"/>
                            </StackPanel>
                        </Border>
                        <lvc:CartesianChart Grid.Row="1" x:Name="chartBarras" Margin="8,4,8,8"/>
                    </Grid>
                </Border>

                <Border Grid.Column="2" CornerRadius="12" Background="{DynamicResource CardBg}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="200"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14" Background="{DynamicResource RankingHeaderBg2}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Star" Width="16" Height="16"
                                             Foreground="{DynamicResource PastelGreen}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Top 5 — Más Puntuales (30 días)"
                                           FontSize="13" FontWeight="Medium" Foreground="{DynamicResource PastelGreen}"/>
                            </StackPanel>
                        </Border>
                        <lvc:CartesianChart Grid.Row="1" x:Name="chartPuntuales" Margin="8,4,8,8"/>
                    </Grid>
                </Border>
            </Grid>

            <!-- HEATMAP -->
            <Border CornerRadius="12" Background="{DynamicResource CardBg}" Margin="0,0,0,20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,14" Background="{DynamicResource AccentBg}">
                        <Grid>
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="CalendarMonth" Width="16" Height="16"
                                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock x:Name="txtHeatmapTitulo" Text="Mapa de Calor — Mes Actual"
                                           FontSize="13" FontWeight="Medium" Foreground="{DynamicResource SectionLabelFg}"/>
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Width="12" Height="12" CornerRadius="2" Background="#81C995" Margin="0,0,4,0"/>
                                <TextBlock Text="Bien" FontSize="10" Foreground="{DynamicResource TextSubtle}" Margin="0,0,12,0"/>
                                <Border Width="12" Height="12" CornerRadius="2" Background="#F4D97D" Margin="0,0,4,0"/>
                                <TextBlock Text="Tardanzas" FontSize="10" Foreground="{DynamicResource TextSubtle}" Margin="0,0,12,0"/>
                                <Border Width="12" Height="12" CornerRadius="2" Background="#E8879B" Margin="0,0,4,0"/>
                                <TextBlock Text="Ausencias" FontSize="10" Foreground="{DynamicResource TextSubtle}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <ItemsControl Grid.Row="1" x:Name="icHeatmap" Margin="16,12,16,16">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ACTIVIDAD RECIENTE -->
            <StackPanel Orientation="Horizontal" Margin="2,0,0,12">
                <md:PackIcon Kind="History" Width="18" Height="18"
                             Foreground="{DynamicResource AccentBlue}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="Actividad Reciente" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource SectionLabelFg}" VerticalAlignment="Center"/>
            </StackPanel>

            <Border CornerRadius="12" Background="{DynamicResource CardBg}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="280"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" CornerRadius="12,12,0,0" Padding="20,12" Background="{DynamicResource AccentBg}">
                        <Grid>
                            <TextBlock Text="Últimos 10 marcajes registrados"
                                       FontSize="13" FontWeight="Medium" Foreground="{DynamicResource SectionLabelFg}"/>
                            <Border HorizontalAlignment="Right" Background="{DynamicResource CounterBg}" CornerRadius="12" Padding="10,3">
                                <TextBlock x:Name="txtContadorReciente" Text="10 registros"
                                           FontSize="11" Foreground="{DynamicResource AccentBlue}" FontWeight="Medium"/>
                            </Border>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="1" x:Name="dgReciente"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              BorderThickness="0" CanUserResizeRows="False"
                              Background="{DynamicResource CardBg}" RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}"
                              Foreground="{DynamicResource TextSecondary}"
                              Style="{DynamicResource MaterialDesignDataGrid}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Empleado" Binding="{Binding NombreEmpleado}" Width="140">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Fecha / Hora" Binding="{Binding FechaHora}" Width="150"/>
                            <DataGridTextColumn Header="Tipo" Binding="{Binding Tipo}" Width="120">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondary}"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTemplateColumn Header="Estado" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" Margin="4,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding EsTardanza}" Value="Sí">
                                                            <Setter Property="Background" Value="{DynamicResource BadgeOrangeBg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding EsTardanza}" FontSize="11" FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding EsTardanza}" Value="Sí">
                                                                <Setter Property="Foreground" Value="{DynamicResource PastelOrange}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
