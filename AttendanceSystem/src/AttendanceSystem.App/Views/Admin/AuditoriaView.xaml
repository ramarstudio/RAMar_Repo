<UserControl x:Class="AttendanceSystem.App.Views.Admin.AuditoriaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource AppBg}" Loaded="AuditoriaView_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- HEADER -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#5C6BC0" Offset="0"/>
                                        <GradientStop Color="#3949AB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <materialDesign:PackIcon Kind="ShieldSearch" Width="22" Height="22"
                                                         Foreground="White" HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Registro de Auditoría" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <TextBlock Text="Historial completo de acciones del sistema" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FILTROS -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="20,16" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="FILTROS" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextLabel}" Margin="0,0,0,12"/>
                    <WrapPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Desde" FontSize="11" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpDesde" Width="150"
                                        materialDesign:HintAssist.Hint="Fecha inicio"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Hasta" FontSize="11" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpHasta" Width="150"
                                        materialDesign:HintAssist.Hint="Fecha fin"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,8">
                            <TextBlock Text="Entidad" FontSize="11" Foreground="{DynamicResource TextDim}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbEntidad" Width="160"
                                      materialDesign:HintAssist.Hint="Todas"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <Button x:Name="btnBuscar" Click="BtnBuscar_Click"
                                Height="40" Padding="20,0" Margin="0,18,0,0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="Buscar"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- CONTADOR -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="16,12" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FormatListBulleted" Foreground="{DynamicResource AccentBlue}" Width="18" Height="18" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtContador" Text="0 registros encontrados" FontSize="13" Foreground="{DynamicResource TextDim}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- TABLA -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="6" Margin="0,0,0,12">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <DataGrid x:Name="dgAudit"
                          Foreground="{DynamicResource TextPrimary}"
                          Background="{DynamicResource CardBg}"
                          RowBackground="{DynamicResource GridRowBg}"
                          AlternatingRowBackground="{DynamicResource GridRowAltBg}"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                          BorderThickness="0"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserSortColumns="True" CanUserResizeColumns="True"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          MaxHeight="500"
                          FontSize="12"
                          AutoGeneratingColumn="DgAudit_AutoGeneratingColumn"/>
            </Border>

            <!-- MENSAJE VACÍO -->
            <TextBlock x:Name="txtVacio" Text="No hay registros de auditoría en el rango seleccionado."
                       Visibility="Collapsed" FontSize="13" Foreground="{DynamicResource TextLabel}"
                       HorizontalAlignment="Center" Margin="0,12,0,0"/>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" Margin="0,8,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
