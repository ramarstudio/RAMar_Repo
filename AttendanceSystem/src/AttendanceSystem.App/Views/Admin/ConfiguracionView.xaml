<UserControl x:Class="AttendanceSystem.App.Views.Admin.ConfiguracionView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource AppBg}" Loaded="ConfiguracionView_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- HEADER -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#FF8F00" Offset="0"/>
                                <GradientStop Color="#F57F17" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <materialDesign:PackIcon Kind="Cog" Width="22" Height="22"
                                                 Foreground="White" HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Configuración del Sistema" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Ajusta los parámetros del sistema — los cambios se aplican de inmediato" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- INFO -->
            <Border Background="{DynamicResource WarningBg}" CornerRadius="10" Padding="16,12" Margin="0,0,0,18"
                    BorderBrush="{DynamicResource WarningBorder}" BorderThickness="1">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ShieldLockOutline" Foreground="{DynamicResource WarningIcon}" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Las claves de seguridad del sistema están protegidas y no se muestran en este panel."
                               FontSize="12" Foreground="{DynamicResource WarningText}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- ═══ PARÁMETROS ACTIVOS ═══ -->
            <TextBlock x:Name="lblActivos" Text="PARÁMETROS ACTIVOS" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}" Margin="4,0,0,10" Visibility="Collapsed"/>

            <ItemsControl x:Name="icConfigs">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20,16" Margin="0,0,0,10"
                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ICONO -->
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                                        Background="{DynamicResource BadgeBlueBg}" Margin="0,0,14,0"
                                        VerticalAlignment="Top">
                                    <materialDesign:PackIcon Kind="{Binding IconoTipo}" Width="20" Height="20"
                                                             Foreground="{DynamicResource AccentBlue}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- CONTENIDO -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Descripcion}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimary}" TextWrapping="Wrap"
                                               Margin="0,0,0,6"/>

                                    <!-- Valor actual -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Valor actual:  " FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                   VerticalAlignment="Center"/>
                                        <Border Background="{DynamicResource CardAltBg}" CornerRadius="4" Padding="10,4"
                                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1">
                                            <TextBlock Text="{Binding ValorAmigable}" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimary}"/>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>

                                <!-- ACCIONES -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                    <Button Click="BtnEditarConfig_Click" Tag="{Binding}"
                                            ToolTip="Editar valor"
                                            Width="36" Height="36" Padding="0"
                                            Style="{StaticResource MaterialDesignIconButton}">
                                        <materialDesign:PackIcon Kind="PencilOutline" Width="18" Height="18"
                                                                 Foreground="{DynamicResource TextMuted}"/>
                                    </Button>
                                    <Button Click="BtnEliminarConfig_Click" Tag="{Binding}"
                                            ToolTip="Eliminar parámetro"
                                            Width="36" Height="36" Padding="0"
                                            Style="{StaticResource MaterialDesignIconButton}">
                                        <materialDesign:PackIcon Kind="TrashCanOutline" Width="18" Height="18"
                                                                 Foreground="{DynamicResource PastelPink}"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ESTADO VACÍO -->
            <Border x:Name="pnlVacio" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="40,40"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <StackPanel HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="CogOutline" Width="48" Height="48"
                                             Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <TextBlock Text="No hay parámetros configurados aún" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextMuted}" HorizontalAlignment="Center" Margin="0,0,0,6"/>
                    <TextBlock Text="Agrega parámetros desde las sugerencias de abajo"
                               FontSize="12" Foreground="{DynamicResource TextDim}" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- PANEL EDITAR VALOR -->
            <Border x:Name="pnlEditar" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Color="#F57F17"/>
                </Border.Effect>
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <materialDesign:PackIcon Kind="PencilOutline" Width="18" Height="18" Foreground="{DynamicResource WarningIcon}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="EDITAR PARÁMETRO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource WarningIcon}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock x:Name="txtDescripcionSeleccionada" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}" Margin="0,0,0,14" TextWrapping="Wrap"/>

                    <!-- Editor para texto/número/decimal -->
                    <StackPanel x:Name="pnlEditorTexto">
                        <TextBlock Text="Nuevo valor" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                        <WrapPanel>
                            <TextBox x:Name="txtNuevoValor" Width="300"
                                     materialDesign:HintAssist.Hint="Ingresa el nuevo valor"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Margin="0,0,12,0"/>
                            <Button x:Name="btnGuardar" Click="BtnGuardar_Click"
                                    Height="40" Padding="20,0" Margin="0,0,8,0"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon Kind="ContentSave" Width="16" Height="16" Margin="0,0,6,0"/>
                                    <TextBlock Text="Guardar"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Cancelar" Click="BtnCancelarEditar_Click"
                                    Height="40" Padding="16,0"
                                    Style="{StaticResource MaterialDesignFlatButton}"/>
                        </WrapPanel>
                    </StackPanel>

                    <!-- Editor para bool -->
                    <StackPanel x:Name="pnlEditorBool" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <ToggleButton x:Name="toggleBool" Click="ToggleBool_Click"
                                          Style="{StaticResource MaterialDesignSwitchToggleButton}"
                                          Margin="0,0,12,0"/>
                            <TextBlock x:Name="txtToggleLabel" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ PARÁMETROS SUGERIDOS (disponibles para agregar) ═══ -->
            <TextBlock x:Name="lblSugeridos" Text="PARÁMETROS DISPONIBLES" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource TextMuted}" Margin="4,8,0,10" Visibility="Collapsed"/>

            <ItemsControl x:Name="icPresets">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource CardBg}" CornerRadius="12" Padding="20,14" Margin="0,0,0,8"
                                BorderBrush="{DynamicResource BorderSubtle}" BorderThickness="1" Opacity="0.75">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ICONO -->
                                <Border Grid.Column="0" Width="38" Height="38" CornerRadius="10"
                                        Background="{DynamicResource CardAltBg}" Margin="0,0,14,0"
                                        VerticalAlignment="Center">
                                    <materialDesign:PackIcon Kind="{Binding Icono}" Width="20" Height="20"
                                                             Foreground="{DynamicResource TextDim}"
                                                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- CONTENIDO -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Descripcion}" FontSize="13" FontWeight="Medium"
                                               Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                                               Margin="0,0,0,3"/>
                                    <TextBlock Foreground="{DynamicResource TextDim}" FontSize="11">
                                        <Run Text="Valor por defecto: "/>
                                        <Run Text="{Binding ValorDefault, Mode=OneWay}" FontWeight="SemiBold"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- BOTÓN AGREGAR -->
                                <Button Grid.Column="2" Click="BtnAgregarPreset_Click" Tag="{Binding}"
                                        VerticalAlignment="Center" Height="32" Padding="14,0"
                                        Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                    <StackPanel Orientation="Horizontal">
                                        <materialDesign:PackIcon Kind="Plus" Width="16" Height="16" Margin="0,0,4,0"/>
                                        <TextBlock Text="Agregar" FontSize="12"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" Margin="0,10,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
