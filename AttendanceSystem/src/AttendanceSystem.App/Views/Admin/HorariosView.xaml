<UserControl x:Class="AttendanceSystem.App.Views.Admin.HorariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource AppBg}" Loaded="HorariosView_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- HEADER -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00897B" Offset="0"/>
                                    <GradientStop Color="#00695C" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <materialDesign:PackIcon Kind="CalendarClock" Width="22" Height="22"
                                                     Foreground="White" HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestión de Horarios" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Asigna horarios personalizados por empleado y día" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnNuevo" Click="BtnNuevo_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="36" Padding="16,0"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Plus" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo Horario"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- FILTRO EMPLEADO -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="20,16" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="SELECCIONAR EMPLEADO" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextLabel}" Margin="0,0,0,10"/>
                    <WrapPanel>
                        <ComboBox x:Name="cmbEmpleado" Width="280"
                                  DisplayMemberPath="Display"
                                  materialDesign:HintAssist.Hint="Empleado"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                  Margin="0,0,12,0"/>
                        <Button x:Name="btnCargar" Click="BtnCargar_Click"
                                Height="40" Padding="20,0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Magnify" Width="18" Height="18" Margin="0,0,6,0"/>
                                <TextBlock Text="Ver Horarios"/>
                            </StackPanel>
                        </Button>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- TABLA HORARIOS -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="6" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <DataGrid x:Name="dgHorarios"
                          Foreground="{DynamicResource TextPrimary}"
                          Background="{DynamicResource CardBg}"
                          RowBackground="{DynamicResource GridRowBg}"
                          AlternatingRowBackground="{DynamicResource GridRowAltBg}"
                          HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                          BorderThickness="0"
                          AutoGenerateColumns="True" IsReadOnly="True"
                          CanUserSortColumns="True" HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          MaxHeight="350" FontSize="12"
                          AutoGeneratingColumn="DgHorarios_AutoGeneratingColumn"/>
            </Border>

            <!-- FORMULARIO NUEVO HORARIO -->
            <Border x:Name="pnlFormulario" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,20"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#00695C"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="NUEVO HORARIO" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource PastelTeal}" Margin="0,0,0,16"/>

                    <WrapPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Empleado" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbEmpleadoForm" Width="220"
                                      DisplayMemberPath="Display"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Día" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <ComboBox x:Name="cmbDia" Width="130"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Entrada (HH:mm)" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtEntrada" Width="110" Text="08:00"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Salida (HH:mm)" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <TextBox x:Name="txtSalida" Width="110" Text="17:00"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                        </StackPanel>
                    </WrapPanel>
                    <WrapPanel Margin="0,4,0,0">
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Vigente Desde" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpVigDesde" Width="150"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,16,12">
                            <TextBlock Text="Vigente Hasta" FontSize="11" Foreground="{DynamicResource FormLabelFg}" Margin="0,0,0,4"/>
                            <DatePicker x:Name="dpVigHasta" Width="150"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>
                        </StackPanel>
                    </WrapPanel>

                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="btnCrear" Click="BtnCrear_Click"
                                Content="Crear Horario" Height="36" Padding="20,0" Margin="0,0,10,0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}"/>
                        <Button Content="Cancelar" Click="BtnCancelar_Click"
                                Height="36" Padding="20,0"
                                Style="{StaticResource MaterialDesignFlatButton}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" Margin="0,4,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
