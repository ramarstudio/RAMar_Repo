<UserControl x:Class="AttendanceSystem.App.Views.Admin.MarcajesAdminView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Loaded="MarcajesAdminView_Loaded"
             Background="{DynamicResource AppBg}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <UserControl.Resources>

        <!-- Tipo badge DataTemplate — dark theme -->
        <DataTemplate x:Key="TipoCellTemplate">
            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tipo}" Value="Entrada">
                                <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tipo}" Value="Salida">
                                <Setter Property="Background" Value="{DynamicResource BadgeRedBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tipo}" Value="BreakInicio">
                                <Setter Property="Background" Value="{DynamicResource BadgeOrangeBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tipo}" Value="BreakFin">
                                <Setter Property="Background" Value="{DynamicResource BadgeOrangeBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Tipo}" FontSize="12" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tipo}" Value="Entrada">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tipo}" Value="Salida">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelPink}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tipo}" Value="BreakInicio">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelOrange}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tipo}" Value="BreakFin">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelOrange}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- Tardanza badge DataTemplate — dark theme -->
        <DataTemplate x:Key="TardanzaCellTemplate">
            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Tardanza}" Value="Si">
                                <Setter Property="Background" Value="{DynamicResource BadgeOrangeBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Tardanza}" Value="No">
                                <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Tardanza}" FontSize="12" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Tardanza}" Value="Si">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelOrange}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Tardanza}" Value="No">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- HEADER -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1E88E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <md:PackIcon Kind="ClipboardClock" Width="22" Height="22"
                                         Foreground="White" HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Gestion de Marcajes" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Consulta y registro manual de asistencias" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Click="BtnMostrarFormManual_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="36" Padding="16,0"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="PencilPlus" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="Marcaje Manual"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- FILTROS -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="20,16" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <Border Width="32" Height="32" CornerRadius="8"
                            Background="{DynamicResource AccentBg}" Margin="0,0,14,0"
                            VerticalAlignment="Center">
                        <md:PackIcon Kind="FilterOutline" Width="16" Height="16"
                                     Foreground="{DynamicResource AccentBlue}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                    </Border>

                    <ComboBox x:Name="cmbEmpleado"
                              Width="210"
                              md:HintAssist.Hint="Empleado"
                              md:HintAssist.IsFloating="True"
                              Style="{StaticResource MaterialDesignOutlinedComboBox}"
                              Margin="0,0,16,0">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" VerticalAlignment="Center" Margin="0,2"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <DatePicker x:Name="dpMes"
                                Width="170"
                                md:HintAssist.Hint="Mes / Ano"
                                md:HintAssist.IsFloating="True"
                                Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                VerticalContentAlignment="Center"
                                Margin="0,0,16,0"/>

                    <Button Click="BtnBuscar_Click" VerticalAlignment="Bottom" Margin="0,0,0,2"
                            Height="36" Padding="16,0"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="Magnify" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Buscar" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <!-- TABLA MARCAJES -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="6" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <!-- Empty state -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding Visibility, ElementName=txtSinMarcajes}">
                        <md:PackIcon Kind="ClockRemove" Width="52" Height="52"
                                     Foreground="{DynamicResource TextDim}"
                                     HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    </StackPanel>
                    <TextBlock x:Name="txtSinMarcajes"
                               Text="Selecciona un empleado y un mes para ver sus marcajes."
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="0,72,0,0"
                               FontSize="14" Foreground="{DynamicResource TextMuted}"
                               Visibility="Visible"/>

                    <DataGrid x:Name="dgMarcajes"
                              Foreground="{DynamicResource TextPrimary}"
                              Background="{DynamicResource CardBg}"
                              RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}"
                              HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                              BorderThickness="0"
                              AutoGenerateColumns="True" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              RowHeight="46"
                              FontSize="12"
                              Visibility="Collapsed"
                              AutoGeneratingColumn="DgMarcajes_AutoGeneratingColumn"/>
                </Grid>
            </Border>

            <!-- RESUMEN -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="16,12" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1A237E"/>
                </Border.Effect>
                <StackPanel Orientation="Horizontal">
                    <md:PackIcon Kind="InformationOutline" Foreground="{DynamicResource AccentBlue}" Width="18" Height="18"
                                 Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtResumen"
                               Text="Sin datos cargados."
                               FontSize="13" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- FORMULARIO MARCAJE MANUAL -->
            <Border x:Name="PanelMarcajeManual" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="0"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1565C0"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="14,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#7EB8DA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,18,20,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <md:PackIcon Kind="PencilPlus" Width="20" Height="20"
                                         Foreground="{DynamicResource AccentBlue}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Registrar Marcaje Manual"
                                       FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="130"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="cmbEmpleadoManual" Grid.Column="0"
                                      md:HintAssist.Hint="Empleado"
                                      md:HintAssist.IsFloating="True"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Display}" VerticalAlignment="Center" Margin="0,2"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <DatePicker x:Name="dpFechaMarcaje" Grid.Column="2"
                                        md:HintAssist.Hint="Fecha"
                                        md:HintAssist.IsFloating="True"
                                        Style="{StaticResource MaterialDesignOutlinedDatePicker}"
                                        VerticalContentAlignment="Center"/>

                            <TextBox x:Name="txtHoraMarcaje" Grid.Column="4"
                                     md:HintAssist.Hint="Hora (HH:mm)"
                                     md:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{DynamicResource TextPrimary}" Text="08:00"/>

                            <Button Grid.Column="6"
                                    Click="BtnConfirmarManual_Click" VerticalAlignment="Bottom"
                                    Height="36" Padding="16,0"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Check" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Registrar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="8"
                                    Click="BtnCancelarManual_Click" VerticalAlignment="Bottom"
                                    Height="36" Padding="16,0"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Close" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" Margin="0,4,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
