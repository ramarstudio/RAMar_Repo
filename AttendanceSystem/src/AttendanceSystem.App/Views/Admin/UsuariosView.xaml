<UserControl x:Class="AttendanceSystem.App.Views.Admin.UsuariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:md="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="900"
             Loaded="UsuariosView_Loaded"
             Background="{DynamicResource AppBg}"
             FontFamily="{DynamicResource MaterialDesignFont}">

    <UserControl.Resources>

        <!-- Rol badge DataTemplate — dark theme -->
        <DataTemplate x:Key="RolCellTemplate">
            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BadgeBlueBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Rol}" Value="Admin">
                                <Setter Property="Background" Value="{DynamicResource BadgeBlueBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Rol}" Value="RRHH">
                                <Setter Property="Background" Value="{DynamicResource BadgePurpleBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Rol}" Value="Empleado">
                                <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Rol}" FontSize="12" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Rol}" Value="Admin">
                                    <Setter Property="Foreground" Value="{DynamicResource AccentBlue}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rol}" Value="RRHH">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelPurple}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Rol}" Value="Empleado">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

        <!-- Estado badge DataTemplate — dark theme -->
        <DataTemplate x:Key="EstadoCellTemplate">
            <Border CornerRadius="10" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Estado}" Value="Activo">
                                <Setter Property="Background" Value="{DynamicResource BadgeGreenBg}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Estado}" Value="Inactivo">
                                <Setter Property="Background" Value="{DynamicResource BadgeRedBg}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="{Binding Estado}" FontSize="12" FontWeight="SemiBold">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Estado}" Value="Activo">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelGreen}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Estado}" Value="Inactivo">
                                    <Setter Property="Foreground" Value="{DynamicResource PastelPink}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>

    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="28,24,28,28">

            <!-- HEADER -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="24,18" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="40" Height="40" CornerRadius="10" Margin="0,0,14,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1565C0" Offset="0"/>
                                    <GradientStop Color="#1E88E5" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <md:PackIcon Kind="AccountMultiple" Width="22" Height="22"
                                         Foreground="White" HorizontalAlignment="Center"
                                         VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Usuarios del Sistema" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock Text="Gestión de accesos y roles" FontSize="12" Foreground="{DynamicResource TextMuted}"/>
                        </StackPanel>
                    </StackPanel>
                    <Button x:Name="btnNuevoUsuario" Click="BtnNuevoUsuario_Click"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Height="36" Padding="16,0"
                            Style="{StaticResource MaterialDesignFlatMidBgButton}">
                        <StackPanel Orientation="Horizontal">
                            <md:PackIcon Kind="AccountPlus" Width="18" Height="18" Margin="0,0,6,0"/>
                            <TextBlock Text="Nuevo Usuario"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- TABLA USUARIOS -->
            <Border Background="{DynamicResource CardBg}" CornerRadius="14" Padding="6" Margin="0,0,0,18">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1A237E"/>
                </Border.Effect>
                <Grid>
                    <!-- Empty state -->
                    <StackPanel x:Name="txtSinUsuarios"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="Collapsed">
                        <md:PackIcon Kind="AccountOff" Width="52" Height="52"
                                     Foreground="{DynamicResource TextDim}"
                                     HorizontalAlignment="Center" Margin="0,0,0,12"/>
                        <TextBlock Text="No se encontraron usuarios."
                                   FontSize="16" Foreground="{DynamicResource TextMuted}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Crea el primer usuario con el botón superior."
                                   FontSize="12" Foreground="{DynamicResource TextDim}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <DataGrid x:Name="dgUsuarios"
                              Foreground="{DynamicResource TextPrimary}"
                              Background="{DynamicResource CardBg}"
                              RowBackground="{DynamicResource GridRowBg}"
                              AlternatingRowBackground="{DynamicResource GridRowAltBg}"
                              HorizontalGridLinesBrush="{DynamicResource BorderSubtle}"
                              BorderThickness="0"
                              AutoGenerateColumns="True" IsReadOnly="True"
                              GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                              CanUserResizeRows="False"
                              SelectionMode="Single"
                              RowHeight="48"
                              FontSize="12"
                              SelectionChanged="DgUsuarios_SelectionChanged"
                              AutoGeneratingColumn="DgUsuarios_AutoGeneratingColumn"/>
                </Grid>
            </Border>

            <!-- ACCIONES FILA SELECCIONADA -->
            <Border x:Name="PanelAcciones" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="0"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Opacity="0.06" Color="#1565C0"/>
                </Border.Effect>
                <StackPanel>
                    <Border Height="3" CornerRadius="14,14,0,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#7EB8DA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Grid Margin="20,14,20,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                            <TextBlock Text="Usuario seleccionado" FontSize="10" Foreground="{DynamicResource TextDim}"/>
                            <TextBlock x:Name="txtAccionesLabel" Text="Seleccionado: —"
                                       FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <Button x:Name="btnToggleActivo" Grid.Column="1"
                                Click="BtnToggleActivo_Click"
                                HorizontalAlignment="Left" VerticalAlignment="Center"
                                Height="36" Padding="16,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="AccountCheck" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Activar / Desactivar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <TextBlock Grid.Column="2" Text="Nueva contraseña"
                                   FontSize="11" Foreground="{DynamicResource TextDim}"
                                   VerticalAlignment="Center" Margin="16,0,8,0"/>

                        <PasswordBox x:Name="pbNuevaPass" Grid.Column="3"
                                     md:HintAssist.Hint="Nueva contraseña"
                                     md:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                     Foreground="{DynamicResource TextPrimary}" Height="40" Margin="0,0,8,0"/>

                        <Button Grid.Column="4"
                                Click="BtnCambiarPass_Click" Margin="0,0,8,0"
                                Height="36" Padding="16,0"
                                Style="{StaticResource MaterialDesignFlatMidBgButton}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Key" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Cambiar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Grid.Column="5"
                                Click="BtnActualizar_Click"
                                Height="36" Padding="16,0"
                                Style="{StaticResource MaterialDesignFlatButton}">
                            <StackPanel Orientation="Horizontal">
                                <md:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Actualizar" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- FORMULARIO NUEVO USUARIO -->
            <Border x:Name="PanelFormNuevo" Background="{DynamicResource CardBg}" CornerRadius="14" Padding="0"
                    Margin="0,0,0,18" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.08" Color="#1565C0"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="4"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" CornerRadius="14,0,0,14">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#1565C0" Offset="0"/>
                                <GradientStop Color="#7EB8DA" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>

                    <StackPanel Grid.Column="1" Margin="20,18,20,18">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <md:PackIcon Kind="AccountPlus" Width="20" Height="20"
                                         Foreground="{DynamicResource AccentBlue}"
                                         VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Registrar Nuevo Usuario"
                                       FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="txtUsername" Grid.Column="0"
                                     md:HintAssist.Hint="Username"
                                     md:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{DynamicResource TextPrimary}"/>

                            <TextBox x:Name="txtNombre" Grid.Column="2"
                                     md:HintAssist.Hint="Nombre completo"
                                     md:HintAssist.IsFloating="True"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"
                                     Foreground="{DynamicResource TextPrimary}"/>

                            <PasswordBox x:Name="pbPassword" Grid.Column="4"
                                         md:HintAssist.Hint="Contraseña"
                                         md:HintAssist.IsFloating="True"
                                         Style="{StaticResource MaterialDesignOutlinedPasswordBox}"
                                         Foreground="{DynamicResource TextPrimary}"/>

                            <ComboBox x:Name="cmbRol" Grid.Column="6"
                                      md:HintAssist.Hint="Rol"
                                      md:HintAssist.IsFloating="True"
                                      Style="{StaticResource MaterialDesignOutlinedComboBox}"
                                      DisplayMemberPath="Nombre"/>

                            <Button Grid.Column="8"
                                    Click="BtnCrearUsuario_Click" VerticalAlignment="Bottom"
                                    Height="36" Padding="16,0"
                                    Style="{StaticResource MaterialDesignFlatMidBgButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="AccountCheck" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Crear" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="10"
                                    Click="BtnCancelarNuevo_Click" VerticalAlignment="Bottom"
                                    Height="36" Padding="16,0"
                                    Style="{StaticResource MaterialDesignFlatButton}">
                                <StackPanel Orientation="Horizontal">
                                    <md:PackIcon Kind="Close" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Cancelar" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- FEEDBACK -->
            <TextBlock x:Name="txtMensaje" Visibility="Collapsed"
                       FontSize="13" Margin="0,4,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
